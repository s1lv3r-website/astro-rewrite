---
import { HIRE_ME_ENABLED, TAGLINE } from "@/constants";
import Layout from "@layouts/Layout.astro";
import HireMe from "@components/HireMe.astro";
import ContactLinks from "@components/ContactLinks.astro";
---

<style lang="scss">
  .indent {
    @media (width >= 48rem) {
      padding-right: 1.25rem;
      padding-left: 1.25rem;
    }
  }

  .tagline {
    margin-top: 0;
  }
</style>

<Layout>
  <div class="about">
    <p class="tagline">
      {TAGLINE}
    </p>
    <p>
      I am highly interested in everything computers, servers, networking, and
      generally technical. I'm also super interested in old mechanical equipment
      and old technology.
    </p>
  </div>

  {HIRE_ME_ENABLED && <HireMe />}

  <ContactLinks />
</Layout>
