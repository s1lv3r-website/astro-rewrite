---
import { SITE_NAME } from "@/constants";
import { getDescription } from "@/utils";
import Layout from "@layouts/Layout.astro";
import type { CollectionEntry } from "astro:content";

type Props = {
  post: CollectionEntry<"blog">;
};

const { post } = Astro.props;
const postData = post.data;
---

<Layout
  title={postData.title}
  description={await getDescription(post)}
  ogtype="article"
>
  <Fragment slot="head">
    <meta property="og:site_name" content={SITE_NAME} />
    {/* only for when linking directly to a blog site */}
    <meta
      property="article:published_time"
      content={postData.pubDate.toISOString()}
    />

    {
      postData.updatedDate && (
        <meta
          property="article:updated_time"
          content={postData.updatedDate.toISOString()}
        />
      )
    }
  </Fragment>

  <slot />
</Layout>
